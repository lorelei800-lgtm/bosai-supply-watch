# Re:Earth CMS connection
VITE_CMS_BASE_URL=https://api.cms.reearth.io
# Format: {workspace-alias}/{project-alias}
VITE_CMS_PROJECT=my-workspace/bosai-supply-watch
VITE_CMS_SHELTER_MODEL=shelter
VITE_CMS_SUPPLY_MODEL=supply-snapshot

# Admin write token — leave empty for public (citizen) build
# Fill in for the internal admin build only
VITE_CMS_TOKEN=
